# YahtzGrid environment variables
# Copy this file to .env and fill in values as needed.
# The app is fully client-side; no server secrets are required for MVP.

# ---------------------------------------------------------------------------
# Public variables (exposed to the browser — must be prefixed NEXT_PUBLIC_)
# ---------------------------------------------------------------------------

# Canonical URL used for Open Graph / Twitter card meta tags.
# Set to your production domain before deploying.
# NEXT_PUBLIC_APP_URL=https://yahtzgrid.example.com

# ---------------------------------------------------------------------------
# Node / Next.js runtime
# ---------------------------------------------------------------------------

# Disable Next.js telemetry in CI / production containers.
NEXT_TELEMETRY_DISABLED=1
